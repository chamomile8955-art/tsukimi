<?xml version="1.0" encoding="UTF-8" ?>
<interface>
  <template parent="AdwBin" class="TuListItem">
    <property name="halign">center</property>
    <property name="valign">start</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="valign">start</property>
        <property name="overflow">visible</property>
        <child>
          <object class="HoverScale" id="hover_scale">
            <property name="valign">start</property>
            <child>
              <object class="GtkOverlay" id="overlay">
                <property name="valign">fill</property>
                <property name="width-request">100</property>
                <property name="height-request">100</property>
                <property name="halign">fill</property>
                <property name="overflow">visible</property>
                <style>
                  <class name="media-card-image"/>
                </style>
                <child type="overlay">
                  <object class="GtkButton" id="played_mark">
                    <property name="halign">start</property>
                    <property name="valign">start</property>
                    <property name="margin-start">8</property>
                    <property name="margin-top">8</property>
                    <property name="icon-name">checkmark-small-symbolic</property>
                    <property name="visible">false</property>
                    <style>
                      <class name="circular"/>
                      <class name="played-mark"/>
                    </style>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkButton" id="folder_mark">
                    <property name="halign">end</property>
                    <property name="valign">start</property>
                    <property name="margin-end">8</property>
                    <property name="margin-top">8</property>
                    <property name="icon-name">folder-visiting-symbolic</property>
                    <property name="visible">false</property>
                    <style>
                      <class name="circular"/>
                      <class name="osd"/>
                      <class name="glass-button"/>
                    </style>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkLabel" id="count_badge">
                    <property name="halign">end</property>
                    <property name="valign">start</property>
                    <property name="margin-end">8</property>
                    <property name="margin-top">8</property>
                    <property name="visible">false</property>
                    <style>
                      <class name="media-count-badge"/>
                    </style>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkButton" id="direct_play_button">
                    <property name="halign">start</property>
                    <property name="valign">end</property>
                    <property name="margin-start">8</property>
                    <property name="margin-bottom">10</property>
                    <property name="icon-name">media-playback-start-symbolic</property>
                    <property name="visible">false</property>
                    <signal name="clicked" handler="on_play_clicked" swapped="yes"/>
                    <style>
                      <class name="circular"/>
                      <class name="osd"/>
                      <class name="glass-button"/>
                      <class name="media-card-play-button"/>
                    </style>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkLabel" id="rating_label">
                    <property name="halign">end</property>
                    <property name="valign">end</property>
                    <property name="margin-end">8</property>
                    <property name="margin-bottom">8</property>
                    <property name="visible">false</property>
                    <style>
                      <class name="media-rating-badge"/>
                    </style>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkLabel" id="playback_label">
                    <property name="halign">end</property>
                    <property name="valign">end</property>
                    <property name="margin-end">8</property>
                    <property name="margin-bottom">10</property>
                    <property name="visible">false</property>
                    <style>
                      <class name="media-playback-badge"/>
                    </style>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkProgressBar" id="progress_bar">
                    <property name="visible">false</property>
                    <property name="valign">end</property>
                    <property name="margin-start">8</property>
                    <property name="margin-end">8</property>
                    <property name="margin-bottom">8</property>
                    <style>
                      <class name="accent"/>
                      <class name="media-card-progress"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">2</property>
            <property name="margin-start">4</property>
            <property name="margin-end">4</property>
            <child>
              <object class="GtkLabel" id="title">
                <property name="justify">left</property>
                <property name="halign">fill</property>
                <property name="xalign">0</property>
                <property name="ellipsize">end</property>
                <property name="lines">1</property>
                <property name="max-width-chars">28</property>
                <property name="visible">false</property>
                <attributes>
                  <attribute name="weight" value="PANGO_WEIGHT_SEMIBOLD"/>
                </attributes>
                <style>
                  <class name="media-card-title"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="subtitle">
                <property name="justify">left</property>
                <property name="halign">fill</property>
                <property name="xalign">0</property>
                <property name="ellipsize">end</property>
                <property name="lines">1</property>
                <property name="visible">false</property>
                <style>
                  <class name="dimmed"/>
                  <class name="media-card-subtitle"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <style>
          <class name="tulistitem"/>
          <class name="media-card"/>
        </style>
      </object>
    </child>
  </template>
</interface>
