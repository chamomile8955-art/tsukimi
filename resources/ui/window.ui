<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="AppWindow" parent="AdwApplicationWindow">
    <property name="title">Tsukimi</property>
    <property name="width-request">500</property>
    <property name="height-request">350</property>
    <property name="icon-name">moe.tsuna.tsukimi</property>
    <child>
      <object class="GtkEventControllerKey">
        <property name="propagation-phase">capture</property>
        <signal name="key-pressed" handler="key_pressed_cb" swapped="yes"/>
        <signal name="key-released" handler="key_released_cb" swapped="yes"/>
      </object>
    </child>
    <child>
      <object class="AdwBreakpoint" id="sidebar_breakpoint">
        <condition>max-width: 500sp</condition>
        <setter object="mpv_view" property="show-sidebar">False</setter>
      </object>
    </child>
    <property name="content">
      <object class="GtkOverlay">
        <child type="overlay">
          <object class="MediaViewer" id="media_viewer">
            <property name="visible">False</property>
          </object>
        </child>
        <child>
          <object class="GtkOverlay">
            <child type="overlay">
              <object class="AdwToastOverlay" id="toast">
                <child>
                  <object class="GtkStack" id="stack">
                    <property name="transition-type">crossfade</property>
                    <property name="transition-duration">200</property>
                    <property name="visible-child-name">main</property>
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">main</property>
                        <property name="child">
                          <object class="AdwOverlaySplitView" id="split_view">
                            <property name="min-sidebar-width">260</property>
                            <property name="max-sidebar-width">360</property>
                            <property name="sidebar-width-fraction">0.14</property>
                            <property name="sidebar">
                              <object class="AdwNavigationPage">
                                <property name="title">Tsukimi</property>
                                <property name="child">
                                  <object class="AdwToolbarView">
                                    <child type="top">
                                      <object class="AdwHeaderBar">
                                        <property name="show-start-title-buttons">false</property>
                                        <property name="title-widget">
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Sources</property>
                                            <style>
                                              <class name="title-3"/>
                                            </style>
                                          </object>
                                        </property>
                                        <child type="start">
                                          <object class="GtkButton">
                                            <property name="icon-name">list-add-symbolic</property>
                                            <property name="tooltip-text" translatable="yes">Add Server</property>
                                            <property name="action-name">win.add-server</property>
                                            <style>
                                              <class name="flat"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child type="bottom">
                                      <object class="AdwActionRow" id="namerow">
                                        <property name="halign">fill</property>
                                        <property name="title-lines">1</property>
                                        <property name="subtitle-lines">1</property>
                                        <child type="prefix">
                                          <object class="AdwAvatar" id="avatar">
                                            <property name="size">30</property>
                                            <property name="margin-start">12</property>
                                            <property name="halign">start</property>
                                            <child>
                                              <object class="GtkGestureClick">
                                                <property name="button">2</property>
                                                <signal name="released" handler="avatar_pressed_cb" swapped="true" />
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <child type="suffix">
                                          <object class="GtkToggleButton">
                                            <property name="valign">center</property>
                                            <property name="icon-name">applications-system-symbolic</property>
                                            <property name="action-name">setting.account</property>
                                            <style>
                                              <class name="flat" />
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <property name="content">
                                      <object class="AdwSidebar" id="selectlist">
                                        <signal name="activated" handler="on_sidebar_activated" swapped="yes"/>
                                        <style>
                                          <class name="source-sidebar"/>
                                        </style>
                                        <child>
                                          <object class="AdwSidebarSection" id="servers_section">
                                            <property name="title" translatable="yes">Servers</property>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                              </object>
                            </property>
                            <property name="content">
                              <object class="AdwNavigationPage" id="navipage">
                                <property name="title" translatable="yes"></property>
                                <property name="child">
                                  <object class="AdwToolbarView">
                                    <property name="bottom-bar-style">raised</property>
                                    <child type="top">
                                      <object class="AdwHeaderBar">
                                        <property name="show-back-button">False</property>
                                        <property name="title-widget">
                                          <object class="GtkBox">
                                            <property name="orientation">horizontal</property>
                                            <property name="spacing">8</property>
                                            <style>
                                              <class name="top-navigation"/>
                                            </style>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Home</property>
                                                <property name="action-name">win.home</property>
                                                <style>
                                                  <class name="flat"/>
                                                  <class name="pill"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Favorites</property>
                                                <property name="action-name">win.favorites</property>
                                                <style>
                                                  <class name="flat"/>
                                                  <class name="pill"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Search</property>
                                                <property name="action-name">win.search</property>
                                                <style>
                                                  <class name="flat"/>
                                                  <class name="pill"/>
                                                </style>
                                              </object>
                                            </child>
                                          </object>
                                        </property>
                                        <child type="start">
                                          <object class="GtkToggleButton" id="sidebar">
                                            <property name="icon-name">sidebar-show-symbolic</property>
                                            <property name="action-name">win.sidebar</property>
                                          </object>
                                        </child>
                                        <child type="start">
                                          <object class="GtkButton" id="popbutton">
                                            <property name="icon-name">go-previous-symbolic</property>
                                            <property name="visible">False</property>
                                            <signal name="clicked" handler="on_pop" swapped="yes"/>
                                          </object>
                                        </child>
                                        <child type="end">
                                          <object class="GtkMenuButton" id="main_menu_button">
                                            <property name="icon-name">open-menu-symbolic</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child type="bottom">
                                      <object class="PlayerToolbarBox" id="player_toolbar_box" />
                                    </child>
                                    <property name="content">
                                      <object class="GtkOverlay">
                                        <child type="overlay">
                                          <object class="GtkProgressBar" id="progressbar">
                                            <property name="hexpand">True</property>
                                            <property name="valign">start</property>
                                            <style>
                                              <class name="osd" />
                                            </style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwNavigationView" id="mainview">
                                            <child>
                                              <object class="AdwNavigationPage" id="mainpage">
                                                <property name="tag">mainpage</property>
                                                <property name="title">Tsukimi</property>
                                                <child>
                                                  <object class="GtkStack" id="insidestack">
                                                    <property name="hexpand">True</property>
                                                    <property name="transition-type">crossfade</property>
                                                    <property name="transition-duration">100</property>
                                                    <property name="visible-child-name">no-server</property>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">homepage</property>
                                                        <property name="child">
                                                          <object class="AdwBin" id="homepage"/>
                                                        </property>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">likedpage</property>
                                                        <property name="child">
                                                          <object class="AdwBin" id="likedpage"/>
                                                        </property>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">searchpage</property>
                                                        <property name="child">
                                                          <object class="AdwBin" id="searchpage"/>
                                                        </property>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">no-server</property>
                                                        <property name="child">
                                                          <object class="AdwStatusPage">
                                                            <property name="valign">center</property>
                                                            <property name="vexpand">True</property>
                                                            <property name="icon-name">network-server-symbolic</property>
                                                            <property name="title" translatable="yes">No Server Selected</property>
                                                            <property name="description" translatable="yes">Add a server from the Sources sidebar to begin.</property>
                                                            <property name="child">
                                                              <object class="GtkButton">
                                                                <property name="label" translatable="yes">Add Server</property>
                                                                <property name="halign">center</property>
                                                                <property name="action-name">win.add-server</property>
                                                                <style>
                                                                  <class name="suggested-action"/>
                                                                  <class name="pill"/>
                                                                </style>
                                                              </object>
                                                            </property>
                                                          </object>
                                                        </property>
                                                      </object>
                                                    </child>
                                                  </object>
                                                </child>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkStackPage" id="mpvpage">
                        <property name="name">mpv</property>
                        <property name="child">
                          <object class="AdwOverlaySplitView" id="mpv_view">
                            <property name="collapsed">False</property>
                            <property name="show-sidebar">False</property>
                            <property name="sidebar-position">end</property>
                            <property name="sidebar">
                              <object class="AdwNavigationPage">
                                <style>
                                  <class name="osd" />
                                </style>
                                <property name="title" translatable="yes">Playlist</property>
                                <property name="child">
                                  <object class="AdwToolbarView">
                                    <child type="top">
                                      <object class="AdwHeaderBar">
                                        <property name="show-end-title-buttons">false</property>
                                        <property name="title-widget">
                                          <object class="AdwViewSwitcher">
                                            <property name="stack">mpv_view_stack</property>
                                          </object>
                                        </property>
                                        <style>
                                          <class name="flat" />
                                        </style>
                                      </object>
                                    </child>
                                    <property name="content">
                                      <object class="AdwViewStack" id="mpv_view_stack">
                                        <child>
                                          <object class="AdwViewStackPage">
                                            <property name="name">playlist</property>
                                            <property name="icon-name">view-list-symbolic</property>
                                            <property name="title" translatable="yes">Playlist</property>
                                            <property name="child">
                                              <object class="GtkScrolledWindow">
                                                <property name="hscrollbar-policy">never</property>
                                                <property name="valign">fill</property>
                                                <property name="margin-bottom">3</property>
                                                <child>
                                                  <object class="GtkListView" id="mpv_playlist">
                                                    <property name="orientation">vertical</property>
                                                    <property name="single-click-activate">True</property>
                                                    <signal name="activate" handler="on_playlist_item_activated" swapped="yes"/>
                                                    <style>
                                                      <class name="vertical-listview" />
                                                      <class name="osd" />
                                                    </style>
                                                  </object>
                                                </child>
                                                <style>
                                                  <class name="undershoot-start" />
                                                  <class name="undershoot-end" />
                                                </style>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwViewStackPage">
                                            <property name="name">control-bar</property>
                                            <property name="icon-name">settings-symbolic</property>
                                            <property name="title" translatable="yes">Advanced Settings</property>
                                            <property name="child">
                                              <object class="MPVControlSidebar" id="mpv_control_sidebar"/>
                                            </property>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                    <style>
                                      <class name="osd" />
                                    </style>
                                  </object>
                                </property>
                              </object>
                            </property>
                            <property name="content">
                              <object class="MPVPage" id="mpvnav">
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkStack" id="backgroundstack">
                <property name="transition-type">crossfade</property>
                <property name="transition-duration">1000</property>
                <child>
                  <object class="GtkPicture" id="rootpic">
                    <property name="halign">fill</property>
                    <property name="valign">fill</property>
                    <property name="content-fit">cover</property>
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="opacity">0.15</property>
                  </object>
                </child>
              </object>
            </child>
            <style>
              <class name="home-carousel" />
            </style>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
