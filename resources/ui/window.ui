<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="AppWindow" parent="AdwApplicationWindow">
    <property name="title">Tsukimi</property>
    <property name="default-width">1360</property>
    <property name="default-height">860</property>
    <property name="icon-name">moe.tsuna.tsukimi</property>
    <style>
      <class name="app-window"/>
    </style>
    <child>
      <object class="GtkEventControllerKey">
        <property name="propagation-phase">capture</property>
        <signal name="key-pressed" handler="key_pressed_cb" swapped="yes"/>
        <signal name="key-released" handler="key_released_cb" swapped="yes"/>
      </object>
    </child>
    <child>
      <object class="AdwBreakpoint" id="sidebar_breakpoint">
        <condition>max-width: 500sp</condition>
        <setter object="mpv_view" property="show-sidebar">False</setter>
      </object>
    </child>
    <property name="content">
      <object class="GtkOverlay" id="window_frame">
        <property name="overflow">hidden</property>
        <style>
          <class name="window-frame"/>
        </style>
        <child type="overlay">
          <object class="MediaViewer" id="media_viewer">
            <property name="visible">False</property>
          </object>
        </child>
        <child>
          <object class="GtkOverlay">
            <property name="overflow">hidden</property>
            <style>
              <class name="window-root-overlay"/>
            </style>
            <child>
              <object class="AdwToastOverlay" id="toast">
                <property name="overflow">hidden</property>
                <style>
                  <class name="window-toast-overlay"/>
                </style>
                <child>
                  <object class="GtkStack" id="stack">
                    <property name="overflow">hidden</property>
                    <property name="transition-type">none</property>
                    <property name="visible-child-name">main</property>
                    <style>
                      <class name="window-stack"/>
                    </style>
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">main</property>
                        <property name="child">
                          <object class="AdwOverlaySplitView" id="split_view">
                            <property name="min-sidebar-width">280</property>
                            <property name="max-sidebar-width">380</property>
                            <property name="sidebar-width-fraction">0.15</property>
                            <style>
                              <class name="app-shell"/>
                            </style>
                            <property name="sidebar">
                              <object class="AdwNavigationPage">
                                <property name="title">Tsukimi</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">8</property>
                                <property name="overflow">hidden</property>
                                <style>
                                  <class name="surface"/>
                                  <class name="source-panel"/>
                                </style>
                                <property name="child">
                                  <object class="AdwToolbarView">
                                    <style>
                                      <class name="source-toolbar"/>
                                    </style>
                                    <child type="top">
                                      <object class="AdwHeaderBar">
                                        <property name="show-start-title-buttons">false</property>
                                        <property name="show-end-title-buttons">false</property>
                                        <style>
                                          <class name="flat"/>
                                          <class name="source-header"/>
                                          <class name="window-titlebar"/>
                                          <class name="unified-header"/>
                                        </style>
                                        <property name="title-widget">
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Sources</property>
                                            <property name="valign">center</property>
                                            <style>
                                              <class name="title-3"/>
                                            </style>
                                          </object>
                                        </property>
                                        <child type="start">
                                          <object class="GtkButton">
                                            <property name="width-request">42</property>
                                            <property name="height-request">42</property>
                                            <property name="valign">center</property>
                                            <property name="icon-name">list-add-symbolic</property>
                                            <property name="tooltip-text" translatable="yes">Add Server</property>
                                            <property name="action-name">win.add-server</property>
                                            <style>
                                              <class name="flat"/>
                                              <class name="circular"/>
                                              <class name="glass-button"/>
                                              <class name="circular-icon-button"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child type="bottom">
                                      <object class="GtkBox">
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <property name="margin-end">12</property>
                                        <property name="margin-top">4</property>
                                        <property name="margin-bottom">4</property>
                                        <child>
                                          <object class="GtkButton">
                                            <property name="width-request">42</property>
                                            <property name="height-request">42</property>
                                            <property name="valign">center</property>
                                            <property name="icon-name">applications-system-symbolic</property>
                                            <property name="tooltip-text" translatable="yes">Settings</property>
                                            <property name="action-name">setting.account</property>
                                            <style>
                                              <class name="flat"/>
                                              <class name="circular"/>
                                              <class name="glass-button"/>
                                              <class name="sidebar-settings-button"/>
                                              <class name="circular-icon-button"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <property name="content">
                                      <object class="AdwSidebar" id="selectlist">
                                        <signal name="activated" handler="on_sidebar_activated" swapped="yes"/>
                                        <style>
                                          <class name="source-sidebar"/>
                                        </style>
                                        <child>
                                          <object class="AdwSidebarSection" id="servers_section">
                                            <property name="title" translatable="yes">Servers</property>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                              </object>
                            </property>
                            <property name="content">
                              <object class="AdwNavigationPage" id="navipage">
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">12</property>
                                <property name="margin-start">4</property>
                                <property name="margin-end">12</property>
                                <property name="title" translatable="yes"></property>
                                <property name="overflow">hidden</property>
                                <style>
                                  <class name="surface"/>
                                  <class name="main-surface"/>
                                </style>
                                <property name="child">
                                  <object class="AdwToolbarView">
                                    <property name="bottom-bar-style">raised</property>
                                    <property name="overflow">hidden</property>
                                    <style>
                                      <class name="main-toolbar"/>
                                    </style>
                                    <child type="top">
                                      <object class="AdwHeaderBar">
                                        <property name="show-back-button">False</property>
                                        <property name="show-start-title-buttons">False</property>
                                        <property name="show-end-title-buttons">False</property>
                                        <style>
                                          <class name="flat"/>
                                          <class name="main-header"/>
                                          <class name="window-titlebar"/>
                                          <class name="unified-header"/>
                                        </style>
                                        <property name="title-widget">
                                          <object class="GtkBox">
                                            <property name="orientation">horizontal</property>
                                            <property name="spacing">8</property>
                                            <property name="valign">end</property>
                                            <property name="margin-top">10</property>
                                            <style>
                                              <class name="top-navigation"/>
                                            </style>
                                            <child>
                                              <object class="GtkToggleButton" id="home_nav">
                                                <property name="label" translatable="yes">Home</property>
                                                <property name="action-name">win.home</property>
                                                <property name="active">True</property>
                                                <style>
                                                  <class name="flat"/>
                                                  <class name="pill"/>
                                                  <class name="segment-button"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkToggleButton" id="favorites_nav">
                                                <property name="label" translatable="yes">Favorites</property>
                                                <property name="action-name">win.favorites</property>
                                                <property name="group">home_nav</property>
                                                <style>
                                                  <class name="flat"/>
                                                  <class name="pill"/>
                                                  <class name="segment-button"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkToggleButton" id="search_nav">
                                                <property name="label" translatable="yes">Search</property>
                                                <property name="action-name">win.search</property>
                                                <property name="group">home_nav</property>
                                                <style>
                                                  <class name="flat"/>
                                                  <class name="pill"/>
                                                  <class name="segment-button"/>
                                                </style>
                                              </object>
                                            </child>
                                          </object>
                                        </property>
                                        <child type="start">
                                          <object class="GtkToggleButton" id="sidebar">
                                            <property name="width-request">42</property>
                                            <property name="height-request">42</property>
                                            <property name="valign">center</property>
                                            <property name="icon-name">sidebar-show-symbolic</property>
                                            <property name="action-name">win.sidebar</property>
                                            <style>
                                              <class name="flat"/>
                                              <class name="circular"/>
                                              <class name="glass-button"/>
                                              <class name="circular-icon-button"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child type="start">
                                          <object class="GtkButton" id="popbutton">
                                            <property name="width-request">42</property>
                                            <property name="height-request">42</property>
                                            <property name="valign">center</property>
                                            <property name="icon-name">go-previous-symbolic</property>
                                            <property name="visible">False</property>
                                            <signal name="clicked" handler="on_pop" swapped="yes"/>
                                            <style>
                                              <class name="flat"/>
                                              <class name="circular"/>
                                              <class name="glass-button"/>
                                              <class name="circular-icon-button"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child type="end">
                                          <object class="GtkWindowControls">
                                            <property name="side">end</property>
                                            <property name="decoration-layout">:minimize,maximize,close</property>
                                            <property name="valign">center</property>
                                            <style>
                                              <class name="macos-window-controls"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child type="end">
                                          <object class="GtkMenuButton" id="main_menu_button">
                                            <property name="width-request">42</property>
                                            <property name="height-request">42</property>
                                            <property name="valign">center</property>
                                            <property name="icon-name">open-menu-symbolic</property>
                                            <style>
                                              <class name="flat"/>
                                              <class name="circular"/>
                                              <class name="glass-button"/>
                                              <class name="circular-icon-button"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child type="bottom">
                                      <object class="PlayerToolbarBox" id="player_toolbar_box" />
                                    </child>
                                    <property name="content">
                                      <object class="GtkOverlay">
                                        <property name="overflow">hidden</property>
                                        <style>
                                          <class name="main-content-pane"/>
                                        </style>
                                        <child type="overlay">
                                          <object class="GtkProgressBar" id="progressbar">
                                            <property name="hexpand">True</property>
                                            <property name="valign">start</property>
                                            <style>
                                              <class name="osd" />
                                            </style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwNavigationView" id="mainview">
                                            <property name="overflow">hidden</property>
                                            <style>
                                              <class name="main-navigation"/>
                                            </style>
                                            <child>
                                              <object class="AdwNavigationPage" id="mainpage">
                                                <property name="tag">mainpage</property>
                                                <property name="title">Tsukimi</property>
                                                <property name="overflow">hidden</property>
                                                <style>
                                                  <class name="main-page"/>
                                                </style>
                                                <child>
                                                  <object class="GtkStack" id="insidestack">
                                                    <property name="overflow">hidden</property>
                                                    <property name="hexpand">True</property>
                                                    <property name="transition-type">none</property>
                                                    <property name="visible-child-name">loading</property>
                                                    <style>
                                                      <class name="content-stack"/>
                                                    </style>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">loading</property>
                                                        <property name="child">
                                                          <object class="GtkBox">
                                                            <property name="orientation">vertical</property>
                                                            <property name="spacing">24</property>
                                                            <property name="margin-top">32</property>
                                                            <property name="margin-start">32</property>
                                                            <property name="margin-end">32</property>
                                                            <style>
                                                              <class name="startup-content-skeleton"/>
                                                            </style>
                                                            <child>
                                                              <object class="GtkBox">
                                                                <property name="spacing">12</property>
                                                                <child>
                                                                  <object class="AdwSpinner"/>
                                                                </child>
                                                                <child>
                                                                  <object class="GtkLabel">
                                                                    <property name="label">正在准备媒体库...</property>
                                                                    <style>
                                                                      <class name="title-3"/>
                                                                    </style>
                                                                  </object>
                                                                </child>
                                                              </object>
                                                            </child>
                                                            <child>
                                                              <object class="GtkFlowBox">
                                                                <property name="column-spacing">24</property>
                                                                <property name="row-spacing">24</property>
                                                                <property name="selection-mode">none</property>
                                                                <property name="homogeneous">True</property>
                                                                <child>
                                                                  <object class="GtkBox"><property name="width-request">220</property><property name="height-request">330</property><style><class name="poster-skeleton"/></style></object>
                                                                </child>
                                                                <child>
                                                                  <object class="GtkBox"><property name="width-request">220</property><property name="height-request">330</property><style><class name="poster-skeleton"/></style></object>
                                                                </child>
                                                                <child>
                                                                  <object class="GtkBox"><property name="width-request">220</property><property name="height-request">330</property><style><class name="poster-skeleton"/></style></object>
                                                                </child>
                                                                <child>
                                                                  <object class="GtkBox"><property name="width-request">220</property><property name="height-request">330</property><style><class name="poster-skeleton"/></style></object>
                                                                </child>
                                                                <child>
                                                                  <object class="GtkBox"><property name="width-request">220</property><property name="height-request">330</property><style><class name="poster-skeleton"/></style></object>
                                                                </child>
                                                                <child>
                                                                  <object class="GtkBox"><property name="width-request">220</property><property name="height-request">330</property><style><class name="poster-skeleton"/></style></object>
                                                                </child>
                                                              </object>
                                                            </child>
                                                          </object>
                                                        </property>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">homepage</property>
                                                        <property name="child">
                                                          <object class="AdwBin" id="homepage"/>
                                                        </property>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">likedpage</property>
                                                        <property name="child">
                                                          <object class="AdwBin" id="likedpage"/>
                                                        </property>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkStackPage">
                                                        <property name="name">searchpage</property>
                                                        <property name="child">
                                                          <object class="AdwBin" id="searchpage"/>
                                                        </property>
                                                      </object>
                                                    </child>
                                                  </object>
                                                </child>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <child type="overlay">
                                          <object class="AdwStatusPage" id="no_server_state">
                                            <property name="visible">False</property>
                                            <property name="valign">fill</property>
                                            <property name="halign">fill</property>
                                            <property name="vexpand">True</property>
                                            <property name="hexpand">True</property>
                                            <property name="icon-name">network-server-symbolic</property>
                                            <property name="title" translatable="yes">No Server Selected</property>
                                            <property name="description" translatable="yes">Add a server from the Sources sidebar to begin.</property>
                                            <style>
                                              <class name="content-state-overlay"/>
                                            </style>
                                            <property name="child">
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Add Server</property>
                                                <property name="halign">center</property>
                                                <property name="action-name">win.add-server</property>
                                                <style>
                                                  <class name="suggested-action"/>
                                                  <class name="pill"/>
                                                  <class name="glass-button"/>
                                                </style>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkStackPage" id="mpvpage">
                        <property name="name">mpv</property>
                        <property name="child">
                          <object class="AdwOverlaySplitView" id="mpv_view">
                            <property name="collapsed">False</property>
                            <property name="show-sidebar">False</property>
                            <property name="sidebar-position">end</property>
                            <property name="sidebar">
                              <object class="AdwNavigationPage">
                                <style>
                                  <class name="osd" />
                                </style>
                                <property name="title" translatable="yes">Playlist</property>
                                <property name="child">
                                  <object class="AdwToolbarView">
                                    <child type="top">
                                      <object class="AdwHeaderBar">
                                        <property name="show-end-title-buttons">false</property>
                                        <property name="title-widget">
                                          <object class="AdwViewSwitcher">
                                            <property name="stack">mpv_view_stack</property>
                                          </object>
                                        </property>
                                        <style>
                                          <class name="flat" />
                                        </style>
                                      </object>
                                    </child>
                                    <property name="content">
                                      <object class="AdwViewStack" id="mpv_view_stack">
                                        <child>
                                          <object class="AdwViewStackPage">
                                            <property name="name">playlist</property>
                                            <property name="icon-name">view-list-symbolic</property>
                                            <property name="title" translatable="yes">Playlist</property>
                                            <property name="child">
                                              <object class="GtkScrolledWindow">
                                                <property name="hscrollbar-policy">never</property>
                                                <property name="valign">fill</property>
                                                <property name="margin-bottom">4</property>
                                                <child>
                                                  <object class="GtkListView" id="mpv_playlist">
                                                    <property name="orientation">vertical</property>
                                                    <property name="single-click-activate">True</property>
                                                    <signal name="activate" handler="on_playlist_item_activated" swapped="yes"/>
                                                    <style>
                                                      <class name="vertical-listview" />
                                                      <class name="osd" />
                                                    </style>
                                                  </object>
                                                </child>
                                                <style>
                                                  <class name="undershoot-start" />
                                                  <class name="undershoot-end" />
                                                </style>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwViewStackPage">
                                            <property name="name">control-bar</property>
                                            <property name="icon-name">settings-symbolic</property>
                                            <property name="title" translatable="yes">Advanced Settings</property>
                                            <property name="child">
                                              <object class="MPVControlSidebar" id="mpv_control_sidebar"/>
                                            </property>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                    <style>
                                      <class name="osd" />
                                    </style>
                                  </object>
                                </property>
                              </object>
                            </property>
                            <property name="content">
                              <object class="MPVPage" id="mpvnav">
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkStack" id="backgroundstack">
                <property name="overflow">hidden</property>
                <property name="transition-type">crossfade</property>
                <property name="transition-duration">1000</property>
                <style>
                  <class name="window-background"/>
                </style>
                <child>
                  <object class="GtkPicture" id="rootpic">
                    <property name="halign">fill</property>
                    <property name="valign">fill</property>
                    <property name="content-fit">cover</property>
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="opacity">0.15</property>
                  </object>
                </child>
              </object>
            </child>
            <style>
              <class name="home-carousel" />
            </style>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
