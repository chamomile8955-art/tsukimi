<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template parent="AdwNavigationPage" class="SingleGrid">
    <property name="title">Tsukimi</property>
    <property name="child">
      <object class="GtkBox">
        <property name="margin-top">0</property>
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <child>
          <object class="GtkCenterBox">
            <property name="margin-top">20</property>
            <child type="start">
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="margin-start">45</property>
                <property name="spacing">8</property>
                <property name="valign">center</property>
                <style>
                  <class name="media-toolbar-summary"/>
                </style>
                <child>
                  <object class="GtkLabel" id="count">
                    <property name="label" translatable="yes"></property>
                    <property name="ellipsize">end</property>
                    <attributes>
                      <attribute name="weight" value="PANGO_WEIGHT_BOLD" />
                    </attributes>
                    <property name="halign">start</property>
                    <property name="valign">center</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="filter">
                    <property name="icon-name">funnel-outline-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Filter Panel</property>
                    <property name="valign">center</property>
                    <signal name="clicked" handler="filter_panel_cb" swapped="yes" />
                    <style>
                      <class name="flat"/>
                      <class name="circular"/>
                      <class name="glass-button"/>
                      <class name="media-filter-button"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
            <child type="end">
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="spacing">8</property>
                <property name="margin-end">55</property>
                <property name="valign">center</property>
                <style>
                  <class name="media-toolbar-actions"/>
                </style>
                <child>
                  <object class="AdwToggleGroup" id="glgroup">
                    <property name="active-name">grid</property>
                    <style>
                      <class name="segmented-control"/>
                      <class name="media-view-switch"/>
                    </style>
                    <child>
                      <object class="AdwToggle">
                        <property name="icon-name">view-grid-symbolic</property>
                        <property name="tooltip" translatable="yes">网格视图</property>
                        <property name="name">grid</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwToggle">
                        <property name="icon-name">view-list-symbolic</property>
                        <property name="tooltip" translatable="yes">列表视图</property>
                        <property name="name">list</property>
                      </object>
                    </child>
                    <signal name="notify::active" handler="on_view_changed_cb" swapped="yes"/>
                  </object>
                </child>

                <child>
                  <object class="AdwToggleGroup" id="adgroup">
                    <style>
                      <class name="segmented-control"/>
                      <class name="media-sort-order"/>
                    </style>
                    <child>
                      <object class="AdwToggle">
                        <property name="icon-name">view-sort-ascending-symbolic</property>
                        <property name="tooltip" translatable="yes">升序</property>
                        <property name="name">asce</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwToggle">
                        <property name="icon-name">view-sort-descending-symbolic</property>
                        <property name="tooltip" translatable="yes">降序</property>
                        <property name="name">desc</property>
                      </object>
                    </child>
                    
                  </object>
                </child>
                <child>
                  <object class="GtkDropDown" id="dropdown">
                    <property name="halign">end</property>
                    <property name="valign">center</property>
                    <property name="tooltip-text" translatable="yes">排序字段</property>
                    <style>
                      <class name="media-sort-dropdown"/>
                    </style>
                    
                    <property name="model">
                      <object class="GtkStringList">
                        <items>
                          <item translatable="yes">标题</item>
                          <item translatable="yes">比特率</item>
                          <item translatable="yes">创建日期</item>
                          <item translatable="yes">IMDb 评分</item>
                          <item translatable="yes">影评人评分</item>
                          <item translatable="yes">首播日期</item>
                          <item translatable="yes">官方分级</item>
                          <item translatable="yes">制作年份</item>
                          <item translatable="yes">播放日期</item>
                          <item translatable="yes">时长</item>
                          <item translatable="yes">更新时间</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkStack" id="stack">
            <property name="transition-type">none</property>
            <property name="transition-duration">0</property>
            <property name="vexpand">True</property>
            <child>
              <object class="GtkStackPage">
                <property name="name">loading</property>
                <property name="title">Loading</property>
                <property name="child">
                  <object class="AdwSpinner">
                    <property name="visible">True</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="width-request">48</property>
                    <property name="height-request">48</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">result</property>
                <property name="title">Result</property>
                <property name="child">
                  <object class="TuViewScrolled" id="scrolled">

                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">fallback</property>
                <property name="title">Fallback</property>
                <property name="child">
                  <object class="AdwStatusPage" id="status">
                    <property name="title" translatable="yes">Nothing Here</property>
                    <property name="vexpand">True</property>
                    <property name="icon-name">document-open-symbolic</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
  <menu id="poster-menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Poster</attribute>
        <attribute name="action">poster</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Backdrop</attribute>
        <attribute name="action">backdrop</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Banner</attribute>
        <attribute name="action">banner</attribute>
      </item>
    </section>
  </menu>
</interface>
